# ─────────────────────────────────────────────────────────────
# Supabase PostgreSQL
# ─────────────────────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by Prisma Migrate / introspection.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─────────────────────────────────────────────────────────────
# AI replies (Step 2)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────────────────────────
# Instagram via Unipile (Step 2)
# ─────────────────────────────────────────────────────────────
# DSN is the Unipile base URL, e.g. apiXX.unipile.com:443XX (scheme optional).
UNIPILE_API_KEY=""
UNIPILE_DSN=""

# ─────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────
# Public base URL for webhooks/callbacks. Leave empty to auto-detect from the
# request (works in Codespaces). Set it for a stable tunnel/prod domain.
# APP_URL=""
# Soft "I'll check and get back" line sent when AI is unsure. Default on.
# AI_HOLDING_LINE="on"
